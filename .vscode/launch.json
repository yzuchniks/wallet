{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger: Django",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/wallet_service/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:8000"
            ],
            "django": true,
            "autoStartBrowser": false
        },
        {
            "name": "Python Debugger: Celery Worker",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/wallet_service/manage.py",
            "args": [
                "celery",
                "-A", "wallet_service.celery",
                "worker",
                "--loglevel=info"
            ],
            "django": false
        }
    ]
}
